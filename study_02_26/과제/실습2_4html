<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Cinema Community</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* 요구사항: 네비게이션 항목 간격 2rem 및 호버 시 밑줄 제거 */
        .nav-link {
            margin-left: 2rem; /* 리스트 끝 배치를 위해 왼쪽 마진 사용 */
            text-decoration: none !important;
            color: rgba(255, 255, 255, 0.5) !important;
        }
        .nav-link:hover {
            color: white !important;
            text-decoration: none !important;
        }
        
        /* 요구사항: 헤더 배경 이미지 전체 적용 및 중앙 정렬 */
        .hero-header {
            /* 이미지 경로를 images/header.jpg로 수정하고 배경으로 설정 */
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('images/header.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            min-height: 90vh; /* 화면의 대부분을 차지하도록 높이 설정 */
            margin-top: 56px; /* 고정 네비게이션 바 두께만큼 여백 */
        }

        /* 텍스트 스타일: 흰색, 굵게 */
        .hero-header h1 {
            color: white;
            font-weight: bold;
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
    <div class="container-fluid px-4">
        <a class="navbar-brand d-flex align-items-center" href="#">
            <img src="images/logo.png" alt="Logo" width="150"> 
        </a>
        <div class="navbar-nav ms-auto">
            <a class="nav-link active text-white" href="#">Home</a>
            <a class="nav-link" href="#">Community</a>
            <a class="nav-link" href="#">Login</a>
        </div>
    </div>
</nav>

<header class="hero-header d-flex flex-column justify-content-center align-items-center text-center">
    <h1 class="display-1">Cinema<br>Community</h1>
    <button class="btn btn-primary btn-lg mt-4 px-5">Let's Go</button>
</header>

<section class="container my-5 py-5 text-center">
    <h2 class="mb-5 fw-bold">Used Skills</h2>
    <div class="row g-4">
        <div class="col-md-4">
            <img src="images/web.png" alt="Web" width="120">
            <p class="mt-3 style= font-size: 0.9rem;">Web</p>
        </div>
        <div class="col-md-4">
            <img src="images/html5.png" alt="HTML5" width="120">
            <p class="mt-3 style= font-size: 0.9rem ;">HTML5</p>
        </div>
        <div class="col-md-4">
            <img src="images/css3.png" alt="CSS3" width="120">
            <p class="mt-3 style= font-size: 0.9rem ;">CSS3</p>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>